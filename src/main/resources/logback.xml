<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%cyan(%d{dd/MM/yy HH:mm:ss}) %highlight(%-5level) %yellow(%logger{20}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Your code — show everything -->
    <logger name="com.beacon" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Hudi — only WARN and above -->
    <logger name="org.apache.hudi" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Spark internals — only ERROR -->
    <logger name="org.apache.spark" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>
    <logger name="org.sparkproject" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Hadoop/HDFS — only ERROR -->
    <logger name="org.apache.hadoop" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- DAG/Task/Executor noise — silence completely -->
    <logger name="org.apache.spark.scheduler" level="OFF" additivity="false"/>
    <logger name="org.apache.spark.executor" level="OFF" additivity="false"/>
    <logger name="org.apache.spark.storage" level="OFF" additivity="false"/>
    <logger name="org.apache.spark.memory" level="OFF" additivity="false"/>
    <logger name="org.apache.spark.broadcast" level="OFF" additivity="false"/>

    <!-- Hudi internal noise — silence -->
    <logger name="org.apache.hudi.client" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>
    <logger name="org.apache.hudi.metadata" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>
    <logger name="org.apache.hudi.io" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Kafka client noise -->
    <logger name="org.apache.kafka" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Jetty / timeline server -->
    <logger name="io.javalin" level="OFF" additivity="false"/>
    <logger name="org.eclipse.jetty" level="OFF" additivity="false"/>

    <!-- Root — catch anything else at WARN -->
    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>